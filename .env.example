# ─────────────────────────────────────────────────────────
# OddsOracle — Variables d'environnement
# ─────────────────────────────────────────────────────────
#
# 1. Copiez ce fichier : cp .env.example .env
# 2. Remplissez votre clé API ci-dessous
# 3. Ne commitez JAMAIS le fichier .env sur GitHub !
#    (il est déjà dans .gitignore)
# ─────────────────────────────────────────────────────────

# Clé API The Odds API (OBLIGATOIRE pour les données live)
# → Gratuit sur https://the-odds-api.com/ (500 req/mois)
# → Inscription en 30 secondes, pas de carte bancaire
ODDS_API_KEY=votre_cle_api_ici

# Port du serveur (optionnel, défaut: 3000)
PORT=3000

# Mode (development ou production)
NODE_ENV=development

# URL externe Render (renseignée automatiquement par Render en production)
# Utilisée pour le keep-alive automatique
# RENDER_EXTERNAL_URL=https://oddsoracle.onrender.com
